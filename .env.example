VITE_API_URL=http://HOST:3000
VITE_WS_URL=ws://HOST:3000
# Auth/tenancy foundation (disabled by default for compatibility)
STEEL_AUTH_ENABLED=false
# STEEL_API_KEY=replace-with-admin-api-key
# STEEL_API_KEYS=[{"key":"sk_steel_...","subject":"service","roles":["service"],"tenantId":"default"}]
# STEEL_AUTH_JWT_SECRET=replace-with-strong-secret
# STEEL_AUTH_USERS=[{"id":"admin","email":"admin@example.com","password":"change-me","roles":["admin"],"tenantId":"default"}]
# STEEL_AUTH_STORE_PATH=/data/steel-auth.json
STEEL_DEFAULT_TENANT_ID=default
STEEL_CORS_ALLOWED_ORIGINS=

# Persistent metadata stores
STEEL_METADATA_STORE_PATH=
STEEL_SESSIONS_STORE_PATH=
STEEL_WORKER_REGISTRY_STORE_PATH=
STEEL_PROXY_STORE_PATH=
STEEL_FILE_METADATA_STORE_PATH=
STEEL_EXTENSIONS_STORE_PATH=
STEEL_TRACE_ARTIFACTS_STORE_PATH=

# Scheduler best-effort session recovery (disabled by default; not live Chrome migration)
STEEL_SESSION_RECOVERY_ENABLED=false
STEEL_SESSION_RECOVERY_AUTO_ALLOCATE=false
STEEL_SESSION_RECOVERY_MAX_ATTEMPTS=1
STEEL_SESSION_RECOVERY_SWEEP_INTERVAL_MS=5000
