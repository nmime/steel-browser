# Server configuration
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
# Use DOMAIN if you want to specify a full domain name instead of HOST:PORT
# DOMAIN=example.com

# Set to true to use HTTPS/WSS instead of HTTP/WS
USE_SSL=false

# Chrome/CDP configuration
CHROME_HEADLESS=true
CHROME_EXECUTABLE_PATH=
CHROME_ARGS=
CDP_REDIRECT_PORT=9223
# CDP_DOMAIN=example.com:9223

# Optional proxy configuration
# PROXY_URL is used as a global fallback when a request does not include proxyUrl.
# proxyUrl remains supported and takes precedence per request/session.
PROXY_URL=
# Optional credentials are applied when PROXY_URL/proxyUrl does not already include credentials.
PROXY_USERNAME=
PROXY_PASSWORD=
# Comma-separated hosts that should bypass the upstream proxy for internal callbacks.
PROXY_BYPASS=0.0.0.0,localhost,127.0.0.1

# Experimental self-hosting foundations (disabled by default)
# These flags only expose no-op/skeleton capability surfaces unless noted in docs.
STEEL_AUTH_ENABLED=false
STEEL_CONTROL_PLANE_ENABLED=false
STEEL_CONTROL_PLANE_PATH=/v1/control-plane
STEEL_WORKER_ENABLED=false
# Runtime split: standalone preserves the existing single-process behavior.
# scheduler exposes /v1/scheduler/* skeleton endpoints; worker exposes /v1/internal/worker/*.
STEEL_ROLE=standalone
# Worker mode heartbeat target and externally reachable worker URL used by schedulers.
# SCHEDULER_URL=http://scheduler:3000
# WORKER_PUBLIC_URL=http://worker-1:3000
# Current worker runtime is intentionally one-session; values >1 are recorded but capped.
WORKER_MAX_SESSIONS=1
# Set false for worker pods that should not keep a warm idle browser between sessions.
WORKER_IDLE_BROWSER=true
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_STALE_AFTER_MS=30000
WORKER_DRAIN_TIMEOUT_MS=30000
STEEL_METADATA_STORE_PATH=
STEEL_SESSIONS_STORE_PATH=
STEEL_WORKER_REGISTRY_STORE_PATH=
STEEL_PROXY_STORE_PATH=
STEEL_FILE_METADATA_STORE_PATH=
STEEL_EXTENSIONS_STORE_PATH=
STEEL_TRACE_ARTIFACTS_STORE_PATH=
STEEL_REMOTE_STORAGE_ENABLED=false
# File storage foundation. Only local is implemented; remote providers can plug into
# the provider interface without changing the Files API.
STEEL_FILE_STORAGE_PROVIDER=local
# Defaults to OS temp files in development/test and /files otherwise.
STEEL_LOCAL_FILE_STORAGE_PATH=
# Optional byte quotas. Empty means use server defaults / unlimited per file.
STEEL_FILE_STORAGE_MAX_BYTES_PER_SESSION=
STEEL_FILE_STORAGE_MAX_BYTES_PER_FILE=
STEEL_CHALLENGE_DETECTION_ENABLED=false
STEEL_PROXY_MANAGEMENT_ENABLED=false

# Vault/profile foundation (optional). Master key must decode to exactly 32 bytes
# (base64, hex, or prefixed base64:/hex:/utf8:). Secret values are encrypted at rest.
# STEEL_VAULT_MASTER_KEY=
# STEEL_VAULT_MASTER_KEY_FILE=
# STEEL_VAULT_STORE_PATH=/tmp/steel-vault.json
# STEEL_PROFILES_STORE_PATH=/tmp/steel-profiles.json

# Extension registry foundation: validates/describes existing local unpacked extensions.
STEEL_EXTENSIONS_REGISTRY_ENABLED=false
# Empty uses the bundled api/extensions directory.
STEEL_EXTENSIONS_DIR=
# Trace/replay artifact metadata foundation. No ffmpeg/ClamAV integration yet.
STEEL_TRACE_ARTIFACTS_ENABLED=false
STEEL_TRACE_ARTIFACTS_DIR=./trace-artifacts
STEEL_TRACE_ARTIFACTS_MAX_BYTES=104857600
STEEL_TRACE_ARTIFACTS_MAX_EVENTS=10000
STEEL_TRACE_ARTIFACTS_PREFIX=telemetry/artifacts

# Logging
LOG_LEVEL=warn # fatal, error, warn, info, debug, trace
ENABLE_CDP_LOGGING=false
LOG_CUSTOM_EMIT_EVENTS=false
ENABLE_VERBOSE_LOGGING=false

# Other configuration options
SKIP_FINGERPRINT_INJECTION=false
DEFAULT_TIMEZONE=
DEFAULT_HEADERS=

# Safe challenge assistance skeleton (disabled by default).
# Only exact origins in this comma-separated allowlist are accepted when enabled.
CHALLENGE_ASSISTANCE_ENABLED=false
# off | detect-only | owned-test-auto. owned-test-auto is for diploma/testing harnesses only.
CHALLENGE_ASSISTANCE_MODE=off
CHALLENGE_ASSISTANCE_ALLOWED_ORIGINS=
CHALLENGE_OWNED_TEST_CALLBACK_SECRET=
CHALLENGE_OWNED_TEST_CALLBACK_MAX_SKEW_MS=300000

# Gated CAPTCHA solver (disabled by default).
# Only list origins you are authorized to automate; respect each site's terms and rate limits.
# Only exact origins in this comma-separated allowlist are accepted when enabled.
CAPTCHA_SOLVER_ENABLED=false
# off | detect-only | auto. detect-only runs /detect but never calls a provider.
CAPTCHA_SOLVER_MODE=auto
# 2captcha | capsolver | anti-captcha | capmonster
CAPTCHA_SOLVER_PROVIDER=2captcha
CAPTCHA_SOLVER_API_KEY=
CAPTCHA_SOLVER_ALLOWED_ORIGINS=
# DANGEROUS: when true, skips the origin allowlist entirely (every origin allowed).
# Off by default. Only enable for trusted, isolated deployments; solves are logged.
CAPTCHA_SOLVER_ALLOW_ANY_ORIGIN=false
CAPTCHA_SOLVER_TIMEOUT_MS=180000
CAPTCHA_SOLVER_POLL_INTERVAL_MS=5000
# Image/puzzle pipeline (Normal/Text/Grid/Rotate/Click/Audio). Separate gate:
# page pixels/audio are exfiltrated to the provider, so it is opt-in on its own.
CAPTCHA_SOLVER_IMAGE_ENABLED=false
CAPTCHA_SOLVER_MAX_IMAGE_BYTES=5242880
# Provider-extension escape hatch: loads a provider's own browser extension from
# STEEL_EXTENSIONS_DIR. The extension solves OUTSIDE the origin gate and holds
# its own API key — only enable if you accept that tradeoff.
CAPTCHA_SOLVER_ALLOW_PROVIDER_EXTENSION=false
# Directory name (under STEEL_EXTENSIONS_DIR) of the provider extension to load.
CAPTCHA_SOLVER_PROVIDER_EXTENSION=
# Auth/tenancy foundation (disabled by default for compatibility)
# STEEL_API_KEY=replace-with-admin-api-key
# STEEL_API_KEYS=[{"key":"sk_steel_...","subject":"service","roles":["service"],"tenantId":"default"}]
# STEEL_AUTH_JWT_SECRET=replace-with-strong-secret
# STEEL_AUTH_USERS=[{"id":"admin","email":"admin@example.com","password":"change-me","roles":["admin"],"tenantId":"default"}]
# STEEL_AUTH_STORE_PATH=/data/steel-auth.json
STEEL_DEFAULT_TENANT_ID=default
STEEL_CORS_ALLOWED_ORIGINS=
